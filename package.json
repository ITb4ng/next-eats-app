{
  "name": "my-app",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "dev:clean": "npm run clean && next dev",
    "build": "next build",
    "build:clean": "npm run clean && next build",
    "start": "next start",
    "lint": "next lint",
    "test:perf:v1.1.0": "node scripts/performance-v1.1.0-runtime-checks.mjs",
    "studio": "npx prisma studio",
    "dev:all": "concurrently \"yarn dev\" \"yarn studio\"",
    "seed:v1.1.0:region-fixtures": "ts-node --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/seed-v1.1.0-region-fixtures.ts",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && prisma migrate deploy && next build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "axios": "1.16.1",
    "dotenv": "^16.6.1",
    "next": "15.5.18",
    "next-auth": "4.24.14",
    "pg": "8.21.0",
    "react": "19.2.6",
    "react-daum-postcode": "^3.2.0",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "react-icons": "5.6.0",
    "react-query": "^3.39.3",
    "react-select": "5.10.2",
    "react-toastify": "11.1.0",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@types/node": "20.19.41",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "concurrently": "9.2.1",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.18",
    "postcss": "8.5.15",
    "prisma": "7.8.0",
    "tailwindcss": "3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "5.8.3"
  },
  "resolutions": {
    "react-query/**/brace-expansion": "1.1.14",
    "react-query/**/minimatch": "3.1.5",
    "**/postcss": "8.5.15",
    "**/preact": "10.29.2",
    "**/uuid": "11.1.1",
    "**/yaml": "1.10.3"
  }
}
